# Killswitch Sentinel Service — Environment Variables
# Copy this file to .env and fill in your values.

# Server
APP_PORT=8000

# Database (PostgreSQL)
POSTGRES_USER=killswitch
POSTGRES_PASSWORD=killswitch_secret
POSTGRES_DB=killswitch_db
DB_HOST=localhost
DB_PORT=5432

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
GUARDIAN_PROGRAM_ID=<your-guardian-program-id>
SENTINEL_KEYPAIR=<your-sentinel-keypair-json-array>

# Telegram
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<your-telegram-chat-id>

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
